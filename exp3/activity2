# Input from user
rows = int(input("Enter number of rows: "))
seats_per_row = int(input("Enter number of seats in each row: "))

# Outer loop for rows
for row in range(1, rows + 1):
    print("Row", row, ":", end=" ")
    
    # Inner loop for seats in each row
    for seat in range(1, seats_per_row + 1):
        print(f"S{seat}", end=" ")
    
    print()
